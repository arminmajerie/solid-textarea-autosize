{
  "name": "@arminmajerie/solid-textarea-autosize",
  "version": "1.0.0",
  "description": "Autosizing textarea component for Solid with modern package exports and TypeScript declarations.",
  "license": "MIT",
  "author": "arminmajerie (https://github.com/arminmajerie)",
  "contributors": [
    "Andrey Popp <8mayday@gmail.com> (https://andreypopp.com/)",
    "Mateusz Burzyński <mateuszburzynski@gmail.com> (https://github.com/Andarist)",
    "Vincent Van Dijck <vandijckv@gmail.com> (https://github.com/bigmistqke)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arminmajerie/solid-textarea-autosize.git"
  },
  "homepage": "https://github.com/arminmajerie/solid-textarea-autosize#readme",
  "bugs": {
    "url": "https://github.com/arminmajerie/solid-textarea-autosize/issues"
  },
  "private": false,
  "sideEffects": false,
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "solid": "./dist/source/index.jsx",
      "browser": {
        "import": "./dist/esm/index.js",
        "require": "./dist/cjs/index.js"
      },
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "peerDependencies": {
    "solid-js": ">=1.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "babel-preset-solid": "^1.9.12",
    "prettier": "^3.8.3",
    "rollup": "^4.60.2",
    "solid-js": "^1.9.12",
    "taze": "^19.11.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vite-plugin-solid": "^2.11.12"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "solid",
    "solid-js",
    "textarea",
    "autosize",
    "textarea-autosize",
    "autogrow"
  ],
  "packageManager": "npm@10.8.2",
  "scripts": {
    "publish:dry-run": "npm publish --dry-run --access public",
    "publish:public": "npm publish --access public",
    "prepublishOnly": "npm run typecheck && npm run build",
    "dev": "vite serve dev",
    "test": "npm run typecheck",
    "build": "tsc -p tsconfig.build.json && rollup -c",
    "pack:check": "npm pack --dry-run",
    "format": "prettier -w \"src/**/*.{js,ts,json,css,tsx,jsx}\" \"dev/**/*.{js,ts,json,css,tsx,jsx}\"",
    "update-deps": "taze -w && npm install",
    "typecheck": "tsc --noEmit"
  }
}
